# Backend API URL for production / mobile APK builds
# IMPORTANT: Change this to your PC's actual IP address on your WiFi network
# Find your IP: run "ipconfig" in terminal, look for "IPv4 Address" under your WiFi adapter
#
# For real phone on same WiFi network:
VITE_API_BASE_URL=http://192.168.137.1:8000/api
#
# For Android emulator (localhost of host machine):
# VITE_API_BASE_URL=http://10.0.2.2:8000/api
